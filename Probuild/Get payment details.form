{
  "components": [
    {
      "text": "### Complete Payment",
      "type": "text",
      "id": "Payment_heading",
      "layout": {
        "row": "row_0",
        "col": 16
      }
    },
    {
      "label": "Loyalty Discount",
      "type": "textfield",
      "key": "discountApplied",
      "readonly": true,
      "appearance": {
        "suffixAdorner": "%"
      },
      "conditional": {
        "hide": "=discountApplied = 0"
      },
      "id": "Field_05tqbeo",
      "layout": {
        "row": "Row_185au4x"
      }
    },
    {
      "label": "Membership Fee",
      "type": "textfield",
      "key": "membershipFee",
      "readonly": true,
      "appearance": {
        "prefixAdorner": "£"
      },
      "conditional": {
        "hide": "=membershipFee = 0"
      },
      "id": "Field_0aasibt",
      "layout": {
        "row": "Row_1dkiuh0"
      }
    },
    {
      "label": "Total Price",
      "type": "textfield",
      "id": "Field_0oc1fpv",
      "key": "totalPrice",
      "readonly": true,
      "appearance": {
        "prefixAdorner": "£"
      },
      "layout": {
        "row": "Row_1y4csib"
      }
    },
{
  "label": "Payment Method",
  "type": "select",
  "id": "PaymentMethod_field",
  "key": "paymentMethod",
  "valuesExpression": "= if in_store_online = \"online\" then [{\"label\":\"Credit Card\",\"value\":\"card\"}] else [{\"label\":\"Cash\",\"value\":\"cash\"},{\"label\":\"Credit Card\",\"value\":\"card\"}]",
  "validate": {
    "required": true
  },
  "layout": {
    "row": "row_1",
    "col": 8
  }
},
    {
      "label": "Cardholder Name",
      "type": "textfield",
      "id": "CardholderName_field",
      "key": "cardholderName",
      "conditional": {
        "hide": "=paymentMethod = \"cash\""
      },
      "validate": {
        "required": true
      },
      "layout": {
        "row": "row_2",
        "col": 16
      }
    },
    {
      "label": "Card Number",
      "type": "textfield",
      "id": "CardNumber_field",
      "key": "cardNumber",
      "conditional": {
        "hide": "=paymentMethod = \"cash\""
      },
      "validate": {
        "required": true,
        "minLength": 16,
        "maxLength": 16
      },
      "layout": {
        "row": "row_3",
        "col": 16
      }
    },
    {
      "label": "Expiry Date (mm/yy)",
      "type": "textfield",
      "id": "ExpiryDate_field",
      "key": "expiryDate",
      "conditional": {
        "hide": "=paymentMethod = \"cash\""
      },
      "validate": {
        "required": true,
        "pattern": "^(0[1-9]|1[0-2])/([0-9]{2})$"
      },
      "layout": {
        "row": "row_4",
        "col": 8
      }
    },
    {
      "label": "CVV",
      "type": "textfield",
      "id": "Cvv_field",
      "key": "cvv",
      "conditional": {
        "hide": "=paymentMethod = \"cash\""
      },
      "validate": {
        "required": true,
        "minLength": 3,
        "maxLength": "3"
      },
      "layout": {
        "row": "row_4",
        "col": 8
      }
    },
    {
      "label": "I confirm the payment details are correct.",
      "type": "checkbox",
      "id": "PaymentConfirmed_field",
      "key": "confirmDetails",
      "validate": {
        "required": true
      },
      "layout": {
        "row": "row_5",
        "col": 16
      },
      "conditional": {
        "hide": "=paymentMethod = \"cash\""
      }
    },
    {
      "label": "I need financial support.",
      "type": "checkbox",
      "layout": {
        "row": "Row_0qhfhhf",
        "columns": null
      },
      "id": "Field_0wplocx",
      "key": "needFinance",
      "properties": {},
      "conditional": {
        "hide": "=paymentMethod = \"cash\" or totalPrice < 100 or toolType= \"HIRE\" or processApplication = \"denied\" "
      }
    },
    {
      "text": "I am liable for the borrowed tools; any damage incurred in the rental period will be attributed to me.",
      "type": "text",
      "layout": {
        "row": "Row_0r2p39i",
        "columns": null
      },
      "id": "Field_0xa9vja",
      "conditional": {
        "hide": "=toolType = \"SALE\""
      }
    },
    {
      "label": "I agree",
      "type": "checkbox",
      "layout": {
        "row": "Row_0lhovlz",
        "columns": null
      },
      "id": "Field_0ydgbyd",
      "key": "checkbox_pip69",
      "validate": {
        "required": true
      },
      "conditional": {
        "hide": "=toolType = \"SALE\""
      }
    },
    {
      "type": "separator",
      "layout": {
        "row": "Row_1b11l6u",
        "columns": 16
      },
      "id": "Field_0hhtdul"
    },
    {
      "text": "### Delivery Address",
      "type": "text",
      "layout": {
        "row": "Row_0bnnz9v",
        "columns": null
      },
      "id": "Field_1nv7nvz",
      "conditional": {
        "hide": "=distributionType = \"pickup\""
      }
    },
    {
      "label": "Address Line",
      "type": "textfield",
      "layout": {
        "row": "Row_1nnbqjb",
        "columns": null
      },
      "id": "Field_1g6s29c",
      "key": "address",
      "conditional": {
        "hide": "=distributionType = \"pickup\""
      },
      "validate": {
        "required": true
      }
    },
    {
      "label": "Postcode",
      "type": "textfield",
      "layout": {
        "row": "Row_1nnbqjb",
        "columns": null
      },
      "id": "Field_03qtz3e",
      "key": "postcode",
      "conditional": {
        "hide": "=distributionType = \"pickup\""
      },
      "validate": {
        "required": true,
        "pattern": "^[A-Z]{1,2}[0-9][0-9A-Z]?\\s?[0-9][A-Z]{2}$"
      }
    },
    {
      "text": "### Credit Application",
      "type": "text",
      "layout": {
        "row": "Row_03y5rfx",
        "columns": null
      },
      "id": "Field_0g62d68",
      "conditional": {
        "hide": "=needFinance = false  or processApplication = \"denied\" "
      }
    },
    {
      "label": "Installment Plan",
      "values": [
        {
          "label": "6 months",
          "value": "6months"
        },
        {
          "label": "12 months",
          "value": "12months"
        }
      ],
      "type": "select",
      "layout": {
        "row": "Row_0xj5q9i",
        "columns": null
      },
      "id": "Field_0qvief2",
      "key": "installment_plan",
      "conditional": {
        "hide": "=needFinance = false  or processApplication = \"denied\" "
      },
      "validate": {
        "required": true
      }
    }
  ],
  "executionPlatform": "Camunda Cloud",
