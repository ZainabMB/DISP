    <bpmn:sequenceFlow id="Flow_1mngjji" sourceRef="Activity_0irjh9u" targetRef="Gateway_0kcno68" />
    <bpmn:sequenceFlow id="Flow_1ow81wm" name="yes" sourceRef="Gateway_0xyaidh" targetRef="Activity_0v8ake2">
