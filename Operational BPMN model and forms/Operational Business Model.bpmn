    <bpmn:sequenceFlow id="Flow_0wepez7" name="are a member" sourceRef="Gateway_0wshhxk" targetRef="Gateway_1u0mvhh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=ismember = "yes_member"</bpmn:conditionExpression>
