    <bpmn:sequenceFlow id="Flow_11qkycl" name="not a member" sourceRef="Gateway_0wshhxk" targetRef="Gateway_1vn6ylg">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=ismember = "no_member"</bpmn:conditionExpression>
