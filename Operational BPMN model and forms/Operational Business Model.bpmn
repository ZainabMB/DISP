    <bpmn:textAnnotation id="TextAnnotation_1o6pxb1">
      <bpmn:text>Add warehouse checking for tool availability?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0mwx6ys">
      <bpmn:text>includes electrical safety checks, wear analysis, and
compliance verification.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ofjx7o">
      <bpmn:text>cleaning, oiling, tightening, calibration,depending on the tool</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_05h3bxq">
      <bpmn:text>via a remote online portal</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_13wyfu3">
      <bpmn:text>Includes Service Summary Report, Exceptions Report, and Invoice Summary</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0yj1fxi">
      <bpmn:text>(date, technician ID, next service date)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1bg4u5c" associationDirection="None" sourceRef="Activity_02joka7" targetRef="TextAnnotation_1ofjx7o" />
