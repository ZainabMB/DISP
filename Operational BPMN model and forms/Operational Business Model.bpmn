    <bpmn:sequenceFlow id="Flow_0amwzqt" name="no" sourceRef="Gateway_0xyaidh" targetRef="Activity_0irjh9u">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needFinance != true </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1cpun4f" sourceRef="Activity_1cdp0pz" targetRef="Gateway_0xyaidh" />
